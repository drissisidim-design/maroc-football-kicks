<div class="gd-collection-page">
  <div class="gd-container">
    <div class="gd-collection-header gd-reveal">
      <p class="gd-section-label">Collection</p>
      <h1 class="gd-section-title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <p style="color:var(--gd-muted);margin-top:.75rem;max-width:600px;">{{ collection.description }}</p>
      {% endif %}
    </div>

    <div class="gd-products-grid">
      {% paginate collection.products by 12 %}
        {% for product in collection.products %}
          <a href="{{ product.url }}" class="gd-product-card gd-reveal">
            <div class="gd-image-wrap">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy" />
              {% else %}
                <div style="width:100%;height:100%;background:var(--gd-card-bg);display:flex;align-items:center;justify-content:center;color:var(--gd-muted);">No Image</div>
              {% endif %}
              {% if product.compare_at_price > product.price %}
                {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                <span class="gd-badge gd-badge-promo">-{{ discount }}%</span>
              {% endif %}
              <div class="gd-hover-overlay"><span>Voir le produit</span></div>
            </div>
            <div class="gd-info">
              <p class="gd-brand">{{ product.vendor }}</p>
              <p class="gd-name">{{ product.title }}</p>
              <div style="display:flex;align-items:center;gap:.5rem;">
                <span class="gd-price">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="gd-price-old">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>
          </a>
        {% endfor %}

        {% if paginate.pages > 1 %}
          <div style="grid-column:1/-1;display:flex;justify-content:center;gap:0.5rem;margin-top:2rem;">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}" class="gd-btn gd-btn-outline" style="padding:.5rem 1rem;font-size:.75rem;">← Précédent</a>
            {% endif %}
            {% if paginate.next %}
              <a href="{{ paginate.next.url }}" class="gd-btn gd-btn-outline" style="padding:.5rem 1rem;font-size:.75rem;">Suivant →</a>
            {% endif %}
          </div>
        {% endif %}
      {% endpaginate %}
    </div>
  </div>
</div>
