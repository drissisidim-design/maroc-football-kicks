<div class="gd-section">
  <div class="gd-container" style="max-width:800px;">
    <h1 class="gd-section-title" style="margin-bottom:2rem;">Votre Panier</h1>

    {% if cart.items.size == 0 %}
      <div style="text-align:center;padding:4rem 0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--gd-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 1rem;"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" x2="21" y1="6" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <p style="color:var(--gd-muted);margin-bottom:1.5rem;">Votre panier est vide</p>
        <a href="/collections/all" class="gd-btn gd-btn-primary">Voir la boutique</a>
      </div>
    {% else %}
      <form action="/cart" method="post">
        {% for item in cart.items %}
          <div class="gd-cart-item" style="display:flex;gap:1.5rem;padding:1.5rem 0;border-bottom:1px solid var(--gd-border);">
            <a href="{{ item.url }}">
              <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" style="width:120px;height:120px;object-fit:cover;border-radius:var(--gd-radius);">
            </a>
            <div style="flex:1;">
              <a href="{{ item.url }}" style="font-weight:500;">{{ item.title }}</a>
              {% if item.variant.title != 'Default Title' %}
                <p style="font-size:.75rem;color:var(--gd-muted);margin-top:.25rem;">{{ item.variant.title }}</p>
              {% endif %}
              <p style="font-family:var(--gd-font-display);color:var(--gd-primary);margin-top:.5rem;text-shadow:var(--gd-neon-glow);">{{ item.final_line_price | money }}</p>
              <div style="display:flex;align-items:center;gap:.75rem;margin-top:.75rem;">
                <div class="gd-qty-controls">
                  <button class="gd-qty-btn" type="button" onclick="updateQty('{{ item.key }}',{{ item.quantity | minus: 1 }})">−</button>
                  <span>{{ item.quantity }}</span>
                  <button class="gd-qty-btn" type="button" onclick="updateQty('{{ item.key }}',{{ item.quantity | plus: 1 }})">+</button>
                </div>
                <button type="button" onclick="updateQty('{{ item.key }}',0)" style="background:none;border:none;color:var(--gd-muted);cursor:pointer;font-size:.75rem;">Supprimer</button>
              </div>
            </div>
          </div>
        {% endfor %}

        <div style="margin-top:2rem;display:flex;justify-content:space-between;align-items:center;">
          <span style="font-family:var(--gd-font-display);font-size:1.5rem;">Total</span>
          <span style="font-family:var(--gd-font-display);font-size:1.5rem;color:var(--gd-primary);text-shadow:var(--gd-neon-glow);">{{ cart.total_price | money }}</span>
        </div>

        <div style="margin-top:1.5rem;display:flex;gap:1rem;">
          <a href="/collections/all" class="gd-btn gd-btn-outline" style="flex:1;justify-content:center;">Continuer les achats</a>
          <button type="submit" name="checkout" class="gd-btn gd-btn-primary gd-neon-glow" style="flex:1;justify-content:center;">Commander</button>
        </div>
      </form>
    {% endif %}
  </div>
</div>
