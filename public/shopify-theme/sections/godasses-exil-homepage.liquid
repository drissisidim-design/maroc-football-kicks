{% comment %}
  ══════════════════════════════════════════════════════════
  GODASSES.MA — Style EXIL.MA (Clean, Minimal, B&W)
  Fichier : sections/godasses-exil-homepage.liquid
  ══════════════════════════════════════════════════════════
{% endcomment %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&display=swap');

  :root {
    --ex-bg: #ffffff;
    --ex-fg: #000000;
    --ex-muted: #737373;
    --ex-border: #e5e5e5;
    --ex-accent: #000000;
    --ex-sale: #e53e3e;
    --ex-badge-bg: #000000;
    --ex-badge-fg: #ffffff;
    --ex-font-display: 'Bebas Neue', sans-serif;
    --ex-font-body: 'Inter', sans-serif;
    --ex-radius: 0;
  }

  /* ── Reset ── */
  .ex-wrapper { font-family: var(--ex-font-body); background: var(--ex-bg); color: var(--ex-fg); -webkit-font-smoothing: antialiased; line-height: 1.5; }
  .ex-wrapper *, .ex-wrapper *::before, .ex-wrapper *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .ex-wrapper a { color: inherit; text-decoration: none; }
  .ex-wrapper img { max-width: 100%; display: block; }
  .ex-container { max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; }

  /* ── Announcement Bar ── */
  .ex-announcement {
    background: var(--ex-fg);
    color: var(--ex-bg);
    text-align: center;
    padding: 0.65rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Navbar ── */
  .ex-navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--ex-bg);
    border-bottom: 1px solid var(--ex-border);
  }
  .ex-navbar-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 4rem;
    gap: 1rem;
  }
  .ex-nav-links { display: flex; gap: 1.75rem; }
  .ex-nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ex-muted);
    transition: color 0.2s;
    text-decoration: none;
    position: relative;
  }
  .ex-nav-link:hover, .ex-nav-link.active {
    color: var(--ex-fg);
  }
  .ex-nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--ex-fg);
  }
  .ex-logo {
    font-family: var(--ex-font-display);
    font-size: 2rem;
    letter-spacing: 0.15em;
    text-align: center;
    color: var(--ex-fg);
  }
  .ex-nav-icons {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
  }
  .ex-icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ex-fg);
    padding: 0.25rem;
    display: flex;
    align-items: center;
  }

  /* ── Hero Split ── */
  .ex-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 70vh;
    overflow: hidden;
  }
  .ex-hero-text {
    background: var(--ex-fg);
    color: var(--ex-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    text-align: center;
  }
  .ex-hero-title {
    font-family: var(--ex-font-display);
    font-size: clamp(3rem, 7vw, 6rem);
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
    line-height: 1;
  }
  .ex-hero-desc {
    font-size: 1rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  .ex-btn {
    display: inline-block;
    font-family: var(--ex-font-body);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 0.875rem 2.5rem;
    border: 2px solid currentColor;
    border-radius: var(--ex-radius);
    transition: all 0.25s ease;
    cursor: pointer;
    text-align: center;
  }
  .ex-btn-white {
    color: var(--ex-bg);
    border-color: var(--ex-bg);
    background: transparent;
  }
  .ex-btn-white:hover {
    background: var(--ex-bg);
    color: var(--ex-fg);
  }
  .ex-btn-black {
    color: var(--ex-bg);
    background: var(--ex-fg);
    border-color: var(--ex-fg);
  }
  .ex-btn-black:hover {
    background: #333;
    border-color: #333;
  }
  .ex-btn-outline {
    color: var(--ex-fg);
    background: transparent;
    border-color: var(--ex-fg);
  }
  .ex-btn-outline:hover {
    background: var(--ex-fg);
    color: var(--ex-bg);
  }
  .ex-hero-img {
    position: relative;
    overflow: hidden;
  }
  .ex-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Section ── */
  .ex-section { padding: 4rem 0; }
  .ex-section-title {
    font-family: var(--ex-font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }

  /* ── Horizontal Product Slider ── */
  .ex-slider-wrap { position: relative; }
  .ex-slider {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
  }
  .ex-slider::-webkit-scrollbar { display: none; }

  /* ── Product Card ── */
  .ex-product {
    flex: 0 0 220px;
    scroll-snap-align: start;
    display: block;
    text-decoration: none;
    color: var(--ex-fg);
  }
  .ex-product-img {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #f5f5f5;
    border-radius: var(--ex-radius);
    margin-bottom: 0.75rem;
  }
  .ex-product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .ex-product:hover .ex-product-img img { transform: scale(1.05); }

  .ex-product-badge {
    position: absolute;
    bottom: 0.5rem;
    left: 0.5rem;
    background: var(--ex-badge-bg);
    color: var(--ex-badge-fg);
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .ex-product-title {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: 0.25rem;
  }
  .ex-product-prices {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    margin-bottom: 0.75rem;
  }
  .ex-price-old {
    color: var(--ex-muted);
    text-decoration: line-through;
  }
  .ex-price-current { font-weight: 600; }

  .ex-choose-btn {
    display: block;
    width: 100%;
    padding: 0.6rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-align: center;
    border: 1.5px solid var(--ex-fg);
    background: transparent;
    color: var(--ex-fg);
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: 0.03em;
  }
  .ex-choose-btn:hover {
    background: var(--ex-fg);
    color: var(--ex-bg);
  }

  /* ── Image Banner ── */
  .ex-banner {
    position: relative;
    height: 60vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ex-banner img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ex-banner-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
  }
  .ex-banner-content {
    position: relative;
    text-align: center;
    color: #fff;
  }
  .ex-banner-title {
    font-family: var(--ex-font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  /* ── Products Grid (for "All products" style) ── */
  .ex-products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .ex-products-grid .ex-product {
    flex: none;
  }

  /* ── Footer ── */
  .ex-footer {
    border-top: 1px solid var(--ex-border);
    padding: 3rem 0 2rem;
    color: var(--ex-muted);
    font-size: 0.875rem;
  }
  .ex-footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .ex-footer h4 {
    font-family: var(--ex-font-body);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ex-fg);
    margin-bottom: 1rem;
  }
  .ex-footer a {
    display: block;
    color: var(--ex-muted);
    font-size: 0.8rem;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }
  .ex-footer a:hover { color: var(--ex-fg); }
  .ex-footer-bottom {
    border-top: 1px solid var(--ex-border);
    padding-top: 1.5rem;
    text-align: center;
    font-size: 0.75rem;
    color: var(--ex-muted);
  }

  /* ── Mobile Toggle ── */
  .ex-mobile-toggle { display: none; background: none; border: none; color: var(--ex-fg); cursor: pointer; padding: 0.25rem; }
  .ex-mobile-menu { display: none; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .ex-hero { grid-template-columns: 1fr; }
    .ex-hero-text { padding: 3rem 1.5rem; min-height: 50vh; }
    .ex-hero-img { height: 50vh; }
    .ex-nav-links { display: none !important; }
    .ex-mobile-toggle { display: flex !important; }
    .ex-mobile-menu.ex-open { display: flex; flex-direction: column; position: absolute; top: 100%; left: 0; right: 0; background: var(--ex-bg); border-bottom: 1px solid var(--ex-border); padding: 1rem 1.5rem; gap: 0.75rem; z-index: 40; }
    .ex-navbar-inner { grid-template-columns: auto 1fr auto; }
    .ex-logo { font-size: 1.5rem; }
    .ex-product { flex: 0 0 180px; }
    .ex-banner { height: 45vh; }
  }
  @media (max-width: 480px) {
    .ex-product { flex: 0 0 160px; }
  }
</style>

<div class="ex-wrapper">

  <!-- ══════════ ANNOUNCEMENT BAR ══════════ -->
  {% if section.settings.announcement_text != blank %}
    <div class="ex-announcement">
      {{ section.settings.announcement_text }}
    </div>
  {% endif %}

  <!-- ══════════ NAVBAR ══════════ -->
  <nav class="ex-navbar">
    <div class="ex-container ex-navbar-inner">
      <div style="display:flex;align-items:center;gap:0.5rem;">
        <button class="ex-mobile-toggle" aria-label="Menu" onclick="document.querySelector('.ex-mobile-menu').classList.toggle('ex-open')">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
        <div class="ex-nav-links">
          <a href="/" class="ex-nav-link active">Home</a>
          <a href="/collections/all" class="ex-nav-link">Catalog</a>
          <a href="/pages/contact" class="ex-nav-link">Contact</a>
        </div>
      </div>

      <a href="/" class="ex-logo">GODASSES</a>

      <div class="ex-nav-icons">
        <a href="/search" class="ex-icon-btn" aria-label="Recherche">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </a>
        <a href="/account/login" class="ex-icon-btn" aria-label="Compte">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
        <a href="/cart" class="ex-icon-btn" style="position:relative;" aria-label="Panier">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" x2="21" y1="6" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          {% if cart.item_count > 0 %}
            <span style="position:absolute;top:-4px;right:-6px;background:var(--ex-fg);color:var(--ex-bg);font-size:0.6rem;font-weight:700;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;">{{ cart.item_count }}</span>
          {% endif %}
        </a>
      </div>
    </div>
    <!-- Mobile menu -->
    <div class="ex-mobile-menu">
      <a href="/" class="ex-nav-link">Home</a>
      <a href="/collections/all" class="ex-nav-link">Catalog</a>
      <a href="/pages/contact" class="ex-nav-link">Contact</a>
    </div>
  </nav>

  <!-- ══════════ HERO SPLIT ══════════ -->
  <section class="ex-hero">
    <div class="ex-hero-text">
      <h1 class="ex-hero-title">{{ section.settings.hero_title | default: 'WELCOME' }}</h1>
      <p class="ex-hero-desc">
        {{ section.settings.hero_line1 | default: 'The look you need.' }}<br>
        {{ section.settings.hero_line2 | default: 'The style you desire.' }}
      </p>
      <a href="{{ section.settings.hero_cta_link | default: '/collections/all' }}" class="ex-btn ex-btn-white">
        {{ section.settings.hero_cta_text | default: 'BUY NOW!' }}
      </a>
    </div>
    <div class="ex-hero-img">
      {% if section.settings.hero_image != blank %}
        <img src="{{ section.settings.hero_image | image_url: width: 1000 }}" alt="{{ section.settings.hero_title | escape }}" loading="eager" />
      {% else %}
        <img src="https://images.unsplash.com/photo-1511886929837-354d827aae26?w=1000&q=80" alt="Hero" loading="eager" />
      {% endif %}
    </div>
  </section>

  <!-- ══════════ COLLECTION SECTIONS (up to 3) ══════════ -->
  {% for i in (1..3) %}
    {% assign col_key = 'collection_' | append: i %}
    {% assign col_handle = section.settings[col_key] %}
    {% if col_handle != blank and collections[col_handle].products.size > 0 %}
      <section class="ex-section">
        <div class="ex-container">
          <h2 class="ex-section-title">{{ collections[col_handle].title | upcase }}</h2>
          <div class="ex-slider-wrap">
            <div class="ex-slider">
              {% for product in collections[col_handle].products limit: 12 %}
                <div class="ex-product">
                  <a href="{{ product.url }}" class="ex-product-img">
                    {% if product.featured_image %}
                      <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title | escape }}" loading="lazy" />
                    {% endif %}
                    {% if product.compare_at_price > product.price %}
                      <span class="ex-product-badge">Sale</span>
                    {% endif %}
                  </a>
                  <p class="ex-product-title">{{ product.title }}</p>
                  <div class="ex-product-prices">
                    {% if product.compare_at_price > product.price %}
                      <span class="ex-price-old">{{ product.compare_at_price | money }}</span>
                    {% endif %}
                    <span class="ex-price-current">{{ product.price | money }}</span>
                  </div>
                  {% if product.variants.size > 1 %}
                    <a href="{{ product.url }}" class="ex-choose-btn">Choose options</a>
                  {% else %}
                    <button class="ex-choose-btn" onclick="
                      fetch('/cart/add.js', {
                        method: 'POST',
                        headers: {'Content-Type':'application/json'},
                        body: JSON.stringify({id: {{ product.variants.first.id }}, quantity: 1})
                      }).then(function(){ window.location.href='/cart'; });
                    ">Add to cart</button>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </section>
    {% endif %}
  {% endfor %}

  <!-- ══════════ IMAGE BANNER ══════════ -->
  {% if section.settings.banner_image != blank %}
    <section class="ex-banner">
      <img src="{{ section.settings.banner_image | image_url: width: 1600 }}" alt="{{ section.settings.banner_title | escape }}" loading="lazy" />
      <div class="ex-banner-overlay"></div>
      <div class="ex-banner-content">
        <h2 class="ex-banner-title">{{ section.settings.banner_title | default: 'NEW COLLECTION' }}</h2>
        <a href="{{ section.settings.banner_link | default: '/collections/all' }}" class="ex-btn ex-btn-white">
          {{ section.settings.banner_cta | default: 'SHOP NOW' }}
        </a>
      </div>
    </section>
  {% endif %}

  <!-- ══════════ ALL PRODUCTS GRID ══════════ -->
  {% if section.settings.show_all_products %}
    <section class="ex-section">
      <div class="ex-container">
        <h2 class="ex-section-title">{{ section.settings.all_products_title | default: 'ALL PRODUCTS' }}</h2>
        <div class="ex-products-grid">
          {% assign all_col = section.settings.all_products_collection | default: 'all' %}
          {% for product in collections[all_col].products limit: 12 %}
            <div class="ex-product">
              <a href="{{ product.url }}" class="ex-product-img">
                {% if product.featured_image %}
                  <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title | escape }}" loading="lazy" />
                {% endif %}
                {% if product.compare_at_price > product.price %}
                  <span class="ex-product-badge">Sale</span>
                {% endif %}
              </a>
              <p class="ex-product-title">{{ product.title }}</p>
              <div class="ex-product-prices">
                {% if product.compare_at_price > product.price %}
                  <span class="ex-price-old">{{ product.compare_at_price | money }}</span>
                {% endif %}
                <span class="ex-price-current">{{ product.price | money }}</span>
              </div>
              {% if product.variants.size > 1 %}
                <a href="{{ product.url }}" class="ex-choose-btn">Choose options</a>
              {% else %}
                <button class="ex-choose-btn" onclick="
                  fetch('/cart/add.js', {
                    method: 'POST',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify({id: {{ product.variants.first.id }}, quantity: 1})
                  }).then(function(){ window.location.href='/cart'; });
                ">Add to cart</button>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  <!-- ══════════ FOOTER ══════════ -->
  <footer class="ex-footer">
    <div class="ex-container">
      <div class="ex-footer-grid">
        <div>
          <span class="ex-logo" style="font-size:1.5rem;display:block;margin-bottom:0.75rem;color:var(--ex-fg);">GODASSES</span>
          <p style="font-size:0.8rem;color:var(--ex-muted);line-height:1.6;">
            {{ section.settings.footer_text | default: 'Your premium streetwear destination in Morocco 🇲🇦' }}
          </p>
        </div>
        <div>
          <h4>Shop</h4>
          <a href="/collections/all">All Products</a>
          <a href="/collections">Collections</a>
        </div>
        <div>
          <h4>Help</h4>
          <a href="/pages/faq">FAQ</a>
          <a href="/pages/shipping">Shipping & Returns</a>
          <a href="/pages/contact">Contact</a>
        </div>
        <div>
          <h4>Contact</h4>
          <p style="font-size:0.8rem;margin-bottom:0.4rem;">contact@godasses.ma</p>
          <p style="font-size:0.8rem;margin-bottom:0.4rem;">+212 6 00 00 00 00</p>
          <p style="font-size:0.8rem;">Casablanca, Maroc</p>
        </div>
      </div>
      <div class="ex-footer-bottom">
        © {{ 'now' | date: '%Y' }} GODASSES.MA — All rights reserved.
      </div>
    </div>
  </footer>

</div>

{% schema %}
{
  "name": "Godasses Exil Homepage",
  "settings": [
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "FREE SHIPPING ON ORDERS OVER 599 DH 📦"
    },
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (right side)"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "WELCOME"
    },
    {
      "type": "text",
      "id": "hero_line1",
      "label": "Line 1",
      "default": "The look you need."
    },
    {
      "type": "text",
      "id": "hero_line2",
      "label": "Line 2",
      "default": "The style you desire."
    },
    {
      "type": "text",
      "id": "hero_cta_text",
      "label": "CTA button text",
      "default": "BUY NOW!"
    },
    {
      "type": "url",
      "id": "hero_cta_link",
      "label": "CTA link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Product Sliders (by collection)"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Collection 1 (e.g. Hoodies)"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Collection 2 (e.g. T-Shirts)"
    },
    {
